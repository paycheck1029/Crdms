# ==============================================================================
# CRDMS Backend Production Environment Configuration
# ==============================================================================

# Server Network Settings
PORT=5000
NODE_ENV=development

# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=crdms_user
DB_PASSWORD=your_secure_db_password_here
DB_NAME=crdms
DB_ROOT_PASSWORD=your_secure_db_root_password_here

# JWT Authentication Config
JWT_SECRET=generate_a_secure_32_byte_hex_string_here
JWT_REFRESH_SECRET=generate_another_secure_32_byte_hex_string_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# SMTP Mail Server Configuration (Environment Configuration Only)
MAIL_HOST=smtp.your-mail-provider.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USERNAME=your_smtp_username_here
MAIL_PASSWORD=your_smtp_password_here
MAIL_FROM_NAME=CRDMS
MAIL_FROM_EMAIL=no-reply@your-domain.com

# Google Cloud Storage Configuration (GCP Integration)
GCS_BUCKET_NAME=your_gcs_uploads_bucket_name_here
GCP_PROJECT_ID=your_gcp_project_id_here
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/gcp/credentials-service-account-key.json

# Automated Database Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE="0 2 * * *"
GCS_BACKUPS_BUCKET_NAME=your_gcs_backups_bucket_name_here
